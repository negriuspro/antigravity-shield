# ============================================================
# ANTIGRAVITY SHIELD — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- General ---
# COMPOSE_PROJECT_NAME is ignored when docker-compose.yml has name: "adblock"
# The project name in use is always "adblock"
TZ=America/Bogota

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=antigravity
POSTGRES_USER=aguser
POSTGRES_PASSWORD=change_me_strong_password

# POSTGRES_PASSWORD_ENCODED: URL-encode del password para usar en DATABASE_URL.
# Los caracteres especiales %  #  @  deben codificarse así:
#   %  →  %25      #  →  %23      @  →  %40
# Ejemplo: si POSTGRES_PASSWORD=abc%#@xyz  →  POSTGRES_PASSWORD_ENCODED=abc%25%23%40xyz
# Herramienta: python3 -c "import urllib.parse; print(urllib.parse.quote('TU_PASSWORD', safe=''))"
POSTGRES_PASSWORD_ENCODED=change_me_url_encoded_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# --- Backend ---
BACKEND_SECRET_KEY=change_me_256bit_random_secret
BACKEND_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_REFRESH_TOKEN_EXPIRE_DAYS=30
BACKEND_CORS_ORIGINS=http://localhost:3000,https://shield.local
BACKEND_RATE_LIMIT_PER_MINUTE=100

# --- AdGuard Home ---
ADGUARD_HOST=adguardhome
ADGUARD_PORT=3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=change_me_adguard_password
# adguard-exporter reads ADGUARD_USER / ADGUARD_PASSWORD above (no extra vars needed)

# --- Alerts ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=antigravity@yourdomain.com
ALERT_EMAIL_TO=admin@yourdomain.com

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# --- ag-controller ---
NETWORK_SCAN_INTERVAL_SECONDS=30
NETWORK_INTERFACE=eth0
NETWORK_SUBNET=192.168.1.0/24

# --- ag-ai ---
AI_MODEL_PATH=/models
AI_CONFIDENCE_THRESHOLD=0.7
